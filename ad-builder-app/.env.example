# Server
ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
INTEL_PORT=3002

# OVG Platform integration
OVG_API_URL=https://ovgweb.onrender.com
OVG_WEBHOOK_SECRET=your-secret-here

# Supabase (for campaign persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Facebook App (for OAuth + Meta API)
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
FB_REDIRECT_URI=https://ads-builder.onrender.com/auth/facebook/callback

# Replicate (AI image fallback, optional)
REPLICATE_API_TOKEN=your-replicate-token

# Vite client-side env (must be prefixed VITE_)
# VITE_INTEL_URL=https://intelligence.onrender.com
